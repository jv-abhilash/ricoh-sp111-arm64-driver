#!/bin/sh
export TMPDIR=/tmp
export HOME=/tmp
export FONTCONFIG_PATH=/etc/fonts
export GS_LIB=/usr/share/ghostscript

TMPPS=$(mktemp /tmp/ricoh-input-XXXXXX.ps)
TMPJBG=$(mktemp /tmp/ricoh-output-XXXXXX.jbg)
LOGFILE=/tmp/ricoh-wrapper.log

echo "=== JOB START $(date) ===" >> $LOGFILE
echo "ARG1=$1 ARG2=$2 ARG3=$3 ARG4=$4 ARG5=$5 ARG6=$6" >> $LOGFILE

# CUPS always passes exactly 5 or 6 args - use positional safely
JOBID="$1"
USER="$2"
# Sanitize title - keep only alphanumeric, dots, dashes, underscores
TITLE=$(echo "$3" | tr -dc '[:alnum:]._-' | cut -c1-50)
# If title is empty after sanitization use fallback
[ -z "$TITLE" ] && TITLE="print_job"
COPIES="$4"
OPTIONS="$5"

cat > "$TMPPS"
echo "INPUT size: $(ls -lh $TMPPS)" >> $LOGFILE

if [ ! -s "$TMPPS" ]; then
    echo "ERROR: Empty input" >> $LOGFILE
    rm -f "$TMPPS" "$TMPJBG"
    exit 1
fi

python3 /opt/ricoh_driver/ricoh-sp1xx-drv.py "$JOBID" "$USER" "$TITLE" "$COPIES" "$OPTIONS" "$TMPPS" > "$TMPJBG" 2>> $LOGFILE
RET=$?
echo "Driver exit: $RET, JBG: $(ls -lh $TMPJBG)" >> $LOGFILE

if [ $RET -eq 0 ] && [ -s "$TMPJBG" ] && [ $(stat -c%s "$TMPJBG") -gt 200 ]; then
    cat "$TMPJBG"
    echo "Sent to stdout" >> $LOGFILE
    USB_DEV=$(ls /dev/usb/lp* 2>/dev/null | head -1)
    if [ -n "$USB_DEV" ] && [ -w "$USB_DEV" ]; then
        cat "$TMPJBG" > "$USB_DEV"
        echo "Also sent to USB $USB_DEV" >> $LOGFILE
    fi
else
    echo "JBG too small or failed" >> $LOGFILE
    rm -f "$TMPPS" "$TMPJBG"
    exit 1
fi

rm -f "$TMPPS" "$TMPJBG"
exit 0
